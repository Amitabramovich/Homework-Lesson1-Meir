using System;				        // כתוב תכנית מחשב הקולטת שני מספרים ומדפיסה האם האחד מתחלק בשני ללא שארית   	

					
public class Program
{
	public static void Main()
	{

        float a = float.Parse(Console.ReadLine());
        float b = float.Parse(Console.ReadLine());
     
        if (a % b == 0)
        {
        	Console.WriteLine("Number {0} can be devided by {1} withour residue", a, b);
        }
        else if (a % b != 0)
        {
        	Console.WriteLine("Number {0} cannot be devided by {1} without residue", a, b);
        }
	}
}
